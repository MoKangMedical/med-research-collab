<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.researchpartner.monitor</string>
    
    <key>ProgramArguments</key>
    <array>
        <string>/Users/linzhang/Desktop/医学科研合作平台/auto_run_monitor.sh</string>
    </array>
    
    <key>StartCalendarInterval</key>
    <array>
        <!-- 每天早上9点 -->
        <dict>
            <key>Hour</key>
            <integer>9</integer>
            <key>Minute</key>
            <integer>0</integer>
        </dict>
        <!-- 每天下午5点 -->
        <dict>
            <key>Hour</key>
            <integer>17</integer>
            <key>Minute</key>
            <integer>0</integer>
        </dict>
    </array>
    
    <key>RunAtLoad</key>
    <false/>
    
    <key>StandardOutPath</key>
    <string>/Users/linzhang/Desktop/医学科研合作平台/launchd_stdout.log</string>
    
    <key>StandardErrorPath</key>
    <string>/Users/linzhang/Desktop/医学科研合作平台/launchd_stderr.log</string>
    
    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
    </dict>
</dict>
</plist>